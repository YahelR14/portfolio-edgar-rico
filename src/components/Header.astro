---
const navItems = [
  { href: "/#perfil", label: "Perfil" },
  { href: "/#habilidades", label: "Habilidades" },
  { href: "/#proyectos", label: "Proyectos" },
  { href: "/#educacion", label: "Educación" },
  { href: "/#contacto", label: "Contacto" },
  { href: "https://github.com/YahelR14", label: "GitHub", external: true },
];
---

<a class="skip-link" href="#contenido">Saltar al contenido</a>

<header class="site-header" aria-label="Navegación principal">
  <div class="site-header__inner">
    <a class="brand-mark" href="/" aria-label="Ir al inicio">
      <span class="brand-mark__symbol" aria-hidden="true">ER</span>
      <span class="brand-mark__text">Edgar Rico</span>
    </a>

    <nav class="site-nav" aria-label="Secciones del sitio">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noreferrer" : undefined}
            aria-label={item.external ? `${item.label} de Edgar Rico, se abre en una pestaña nueva` : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
