---
const { project } = Astro.props;
const slug = project.id.replace(/\.md$/, "");
const isLead = project.data.highlight;

const statusLabels = {
  completed: "Completado",
  "in-progress": "En desarrollo",
  planned: "Planeado",
};
---

<article class:list={["project-card", { "project-card--lead": isLead }]}>
  <div class="project-card__topline">
    {isLead && <span class="project-card__lead">Caso principal</span>}
    <span class="project-card__status">{statusLabels[project.data.status]}</span>
    <span>{project.data.role}</span>
  </div>
  <h3>{project.data.title}</h3>
  <p>{project.data.shortDescription}</p>
  {
    project.data.evidence.length > 0 && (
      <ul class="project-card__evidence" aria-label={`Evidencia de ${project.data.title}`}>
        {project.data.evidence.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    )
  }
  <ul class="project-card__tags" aria-label={`Tecnologías usadas en ${project.data.title}`}>
    {
      project.data.technologies.map((technology) => (
        <li>{technology}</li>
      ))
    }
  </ul>
  <div class="project-card__actions">
    <a href={`/proyectos/${slug}/`} aria-label={`Ver caso de estudio de ${project.data.title}`}>
      Ver caso de estudio
    </a>
    {
      project.data.repositoryUrl && (
        <a href={project.data.repositoryUrl} target="_blank" rel="noreferrer" aria-label={`Repositorio de ${project.data.title}, se abre en una pestaña nueva`}>
          Repositorio
        </a>
      )
    }
    {
      project.data.demoUrl && (
        <a href={project.data.demoUrl} target="_blank" rel="noreferrer" aria-label={`Demo de ${project.data.title}, se abre en una pestaña nueva`}>
          Demo
        </a>
      )
    }
  </div>
</article>
