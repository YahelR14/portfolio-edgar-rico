---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Edgar Rico | Software Engineering Portfolio",
  description = "Portfolio profesional de Edgar Rico, estudiante de Ingeniería de Software con evidencia en desarrollo web, análisis de requisitos, bases de datos, UX/UI y calidad de software.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
